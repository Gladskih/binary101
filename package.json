{
  "name": "binary101",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "imports": {
    "#iced-x86-loader": "./analyzers/x86/load-iced-x86.node.ts"
  },
  "license": "MIT",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "prepare:iced-x86": "node scripts/prepare-iced-x86.mjs",
    "predev": "npm run prepare:iced-x86",
    "dev": "vite",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.tests.json && tsc --noEmit -p tsconfig.scripts.json",
    "prebuild": "npm run prepare:iced-x86",
    "build": "vite build",
    "preview": "vite preview",
    "test": "npm run build && npm run test:unit && npm run test:e2e",
    "test:unit": "tsx --test tests/unit/**/*.ts",
    "test:coverage": "c8 --config .c8rc.json tsx --test tests/unit/**/*.ts",
    "test:mutation": "stryker run",
    "test:mutation:pe": "npm run test:mutation",
    "test:mutation:pe:dry-run": "npm run test:mutation -- --dryRunOnly",
    "test:mutation:pe:bound-imports": "npm run test:mutation -- --mutate analyzers/pe/bound-imports.ts --testFiles tests/unit/pe.bound-imports.test.ts --incrementalFile reports/mutation/stryker-incremental.pe.bound-imports.json",
    "test:mutation:pe:clr-metadata-root": "npm run test:mutation -- --mutate analyzers/pe/clr-metadata-root.ts --testFiles tests/unit/pe.clr-metadata-root.test.ts --incrementalFile reports/mutation/stryker-incremental.pe.clr-metadata-root.json",
    "test:e2e": "playwright test",
    "test:elf-wsl": "tsx --test tests/external/analyzers.elf.wsl-readelf.test.ts",
    "test:pe-extreme": "tsx --test tests/external/analyzers.pe.extreme-fixtures.test.ts",
    "fetch:pe-fixtures": "tsx scripts/fetchExternalPeFixtures.ts"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@stryker-mutator/core": "^9.6.0",
    "@stryker-mutator/tap-runner": "^9.6.0",
    "@stryker-mutator/typescript-checker": "^9.6.0",
    "@types/node": "^24.12.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@xmldom/xmldom": "^0.9.9",
    "c8": "^11.0.0",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "iced-x86": "^1.21.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.0"
  },
  "dependencies": {
    "pkijs": "^3.4.0"
  }
}
