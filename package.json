{
  "name": "binary101",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "imports": {
    "#iced-x86-loader": "./analyzers/x86/load-iced-x86.node.ts"
  },
  "license": "MIT",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "prepare:iced-x86": "node scripts/prepare-iced-x86.mjs",
    "generate:winapi-metadata": "tsx scripts/winapi-metadata/generate.ts",
    "validate:winapi-metadata": "tsx scripts/winapi-metadata/validate.ts",
    "generate:ucrt-metadata": "tsx scripts/ucrt-metadata/generate.ts",
    "validate:ucrt-metadata": "tsx scripts/ucrt-metadata/validate.ts",
    "generate:api-metadata": "npm run generate:winapi-metadata && npm run generate:ucrt-metadata",
    "validate:api-metadata": "npm run validate:winapi-metadata && npm run validate:ucrt-metadata",
    "scan:pe-import-metadata": "tsx scripts/peImportMetadataScan.ts",
    "scan:file-types": "tsx scripts/fileTypeDiskScan.ts",
    "predev": "npm run prepare:iced-x86",
    "dev": "vite",
    "lint": "npm run lint:ts && npm run lint:css",
    "lint:ts": "eslint .",
    "lint:css": "stylelint \"**/*.css\" --ignore-path .gitignore",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.tests.json && tsc --noEmit -p tsconfig.scripts.json",
    "prebuild": "npm run prepare:iced-x86",
    "build": "vite build",
    "build:with-winapi-metadata": "npm run generate:winapi-metadata && npm run validate:winapi-metadata && npm run build",
    "build:with-api-metadata": "npm run generate:api-metadata && npm run validate:api-metadata && npm run build",
    "preview": "vite preview",
    "test": "npm run build && npm run test:unit && npm run test:e2e",
    "test:unit": "tsx --test --test-reporter=dot tests/unit/**/*.ts",
    "test:coverage": "c8 --config .c8rc.json tsx --test --test-reporter=dot tests/unit/**/*.ts",
    "test:mutation": "stryker run",
    "test:mutation:pe": "npm run test:mutation",
    "test:mutation:pe:dry-run": "npm run test:mutation -- --dryRunOnly",
    "test:mutation:pe:bound-imports": "npm run test:mutation -- --mutate analyzers/pe/imports/bound.ts --testFiles tests/unit/analyzers/pe/imports/bound.test.ts --incrementalFile reports/mutation/stryker-incremental.pe.bound-imports.json",
    "test:mutation:pe:clr-metadata-root": "npm run test:mutation -- --mutate analyzers/pe/clr/metadata-root.ts --testFiles tests/unit/analyzers/pe/clr/metadata-root/index.test.ts --incrementalFile reports/mutation/stryker-incremental.pe.clr-metadata-root.json",
    "test:mutation:pe:msvc-rtti": "npm run test:mutation -- --mutate analyzers/pe/msvc-rtti/**/*.ts --testFiles tests/unit/analyzers/pe/msvc-rtti/*.test.ts --incrementalFile reports/mutation/stryker-incremental.pe.msvc-rtti.json",
    "test:mutation:coff": "npm run test:mutation:coff:core",
    "test:mutation:coff:core": "npm run test:mutation -- --mutate analyzers/coff/debug-string-table.ts,analyzers/coff/file-header.ts,analyzers/coff/layout.ts,analyzers/coff/lines.ts,analyzers/coff/probe.ts,analyzers/coff/relocations.ts,analyzers/coff/section-headers.ts,analyzers/coff/section-string-table.ts,analyzers/coff/symbols.ts --testFiles tests/unit/**/*.ts --incrementalFile reports/mutation/stryker-incremental.coff.core.json",
    "test:mutation:coff:full": "npm run test:mutation -- --mutate analyzers/coff/**/*.ts,renderers/coff/**/*.ts --testFiles tests/unit/**/*.ts --incrementalFile reports/mutation/stryker-incremental.coff.json",
    "test:e2e": "playwright test",
    "test:elf-wsl": "tsx --test tests/external/analyzers.elf.wsl-readelf.test.ts",
    "test:pe-extreme": "tsx --test tests/external/analyzers.pe.extreme-fixtures.test.ts",
    "fetch:pe-fixtures": "tsx scripts/fetchExternalPeFixtures.ts",
    "build:pe-samples": "tsx scripts/pe-disassembly-samples/index.ts"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@stryker-mutator/core": "^9.6.0",
    "@stryker-mutator/tap-runner": "^9.6.0",
    "@stryker-mutator/typescript-checker": "^9.6.0",
    "@stylistic/stylelint-plugin": "^5.2.1",
    "@types/node": "^24.12.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@xmldom/xmldom": "^0.9.9",
    "c8": "^12.0.0",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "iced-x86": "^1.21.0",
    "stylelint": "^17.14.1",
    "stylelint-config-standard": "^40.0.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.0"
  },
  "dependencies": {
    "@noble/hashes": "2.2.0",
    "lzma-web": "^4.0.0-rc.5",
    "pkijs": "^3.4.0"
  }
}
